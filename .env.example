# AWS
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=

# Bedrock — in ap-south-1 use APAC inference profile (on-demand foundation model id alone fails)
BEDROCK_MODEL_ID=apac.amazon.nova-lite-v1:0

# SES — verify identities in the SES console (sandbox requires verified from AND to)
SES_FROM_EMAIL=you@example.com
SES_TO_EMAIL=you@example.com

# EventBridge Scheduler
SCHEDULE_TIMEZONE=Asia/Kolkata
# Cron: 8:00 AM daily in SCHEDULE_TIMEZONE
SCHEDULE_EXPRESSION=cron(0 8 * * ? *)

# Agent run limits
ANALYSIS_CAP=10

# DynamoDB (populated after CDK deploy via stack outputs)
TABLE_NAME=

# Agent local/dev helpers (Lambda does not set these)
# USER_ID=default
# AGENT_DRY_RUN=true

# Next.js web app (local)
NEXT_PUBLIC_APP_NAME=Opportun-AI-t
# Server-side DynamoDB access for the control center (same table as the agent)
# TABLE_NAME=          # reuse above after deploy
# AWS_REGION=ap-south-1 # reuse above
# DEMO_MODE=1 forces in-memory demo data (default when TABLE_NAME is empty)
# DEMO_MODE=0 requires TABLE_NAME + AWS credentials for live DynamoDB
